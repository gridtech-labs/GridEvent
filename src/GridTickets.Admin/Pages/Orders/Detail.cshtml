@page "{id:guid}"
@model GridTickets.Admin.Pages.Orders.OrderDetailModel
@{
    ViewData["Title"] = $"Order #{Model.Order?.Id.ToString()[..8].ToUpper()}";
}

@if (Model.Order is null)
{
    <p class="text-danger">Order not found.</p>
    return;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1 fw-semibold">Order #@Model.Order.Id.ToString()[..8].ToUpper()</h5>
        <p class="text-muted small mb-0">Created @Model.Order.CreatedAt.ToString("dd MMM yyyy HH:mm") UTC</p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge fs-6 @Model.StatusBadgeClass">@Model.Order.Status</span>
        <a asp-page="/Orders/Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Left column -->
    <div class="col-lg-8">
        <!-- Event info -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold border-bottom py-3">Event</div>
            <div class="card-body">
                <p class="fw-semibold mb-1">@Model.Order.EventTitle</p>
                <p class="text-muted small mb-1">@Model.Order.EventVenue</p>
                <p class="text-muted small">@Model.Order.EventStartDate.ToString("dd MMM yyyy HH:mm") UTC</p>
            </div>
        </div>

        <!-- Ticket items -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold border-bottom py-3">Tickets</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Tier</th>
                            <th>Qty</th>
                            <th>Unit Price</th>
                            <th class="text-end pe-4">Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Order.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">@item.TierName</td>
                                <td>@item.Quantity</td>
                                <td>₹@item.UnitPrice.ToString("N0")</td>
                                <td class="text-end pe-4">₹@item.LineTotal.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-white">
                <div class="d-flex justify-content-end gap-4 small text-muted">
                    <span>Subtotal: <strong>₹@Model.Order.SubTotal.ToString("N0")</strong></span>
                    <span>Booking fee: <strong>₹@Model.Order.BookingFee.ToString("N2")</strong></span>
                    <span class="text-dark fw-bold">Grand Total: ₹@Model.Order.GrandTotal.ToString("N0")</span>
                </div>
            </div>
        </div>

        <!-- Payment info -->
        @if (!string.IsNullOrEmpty(Model.Order.RazorpayOrderId))
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold border-bottom py-3">Payment</div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-sm-4 text-muted">Razorpay Order ID</dt>
                        <dd class="col-sm-8 font-monospace">@Model.Order.RazorpayOrderId</dd>
                        @if (!string.IsNullOrEmpty(Model.Order.RazorpayPaymentId))
                        {
                            <dt class="col-sm-4 text-muted">Payment ID</dt>
                            <dd class="col-sm-8 font-monospace">@Model.Order.RazorpayPaymentId</dd>
                        }
                    </dl>
                </div>
            </div>
        }
    </div>

    <!-- Right column -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold border-bottom py-3">Customer</div>
            <div class="card-body small">
                <p class="fw-semibold mb-1">@Model.Order.CustomerName</p>
                <p class="text-muted mb-1">@Model.Order.CustomerEmail</p>
                <p class="text-muted mb-0">@Model.Order.CustomerPhone</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-bottom py-3">Timeline</div>
            <div class="card-body small">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Created</span>
                    <span>@Model.Order.CreatedAt.ToString("dd MMM yy HH:mm")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Expires</span>
                    <span class="@(Model.Order.Status == "Pending" && Model.Order.ExpiresAt < DateTime.UtcNow ? "text-danger" : "")">
                        @Model.Order.ExpiresAt.ToString("dd MMM yy HH:mm")
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>
