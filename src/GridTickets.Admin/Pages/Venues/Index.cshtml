@page
@model GridTickets.Admin.Pages.Venues.VenuesIndexModel
@{
    ViewData["Title"] = "Venues";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1 fw-semibold">Venue Management</h5>
        <p class="text-muted small mb-0">@Model.TotalCount total venues</p>
    </div>
    <a asp-page="/Venues/Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Add Venue
    </a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <input type="text" name="search" value="@Model.Search"
                       class="form-control form-control-sm" placeholder="Search by name or city..." />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search me-1"></i>Filter
                </button>
                <a asp-page="/Venues/Index" class="btn btn-outline-secondary btn-sm ms-1">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Name</th>
                    <th>City</th>
                    <th>State</th>
                    <th>Capacity</th>
                    <th>Added</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Venues.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No venues found.</td></tr>
                }
                @foreach (var v in Model.Venues)
                {
                    <tr>
                        <td class="ps-4 fw-medium">@v.Name</td>
                        <td>@v.City</td>
                        <td>@v.State</td>
                        <td>@v.Capacity.ToString("N0")</td>
                        <td class="text-muted small">@v.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-page="/Venues/Edit" asp-route-id="@v.Id"
                               class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    onclick="confirmDelete('@v.Id', '@v.Name')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">
                Showing @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount))
                of @Model.TotalCount
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="/Venues/Index"
                           asp-route-page="@(Model.Page - 1)" asp-route-search="@Model.Search">&laquo;</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-page="/Venues/Index"
                               asp-route-page="@i" asp-route-search="@Model.Search">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="/Venues/Index"
                           asp-route-page="@(Model.Page + 1)" asp-route-search="@Model.Search">&raquo;</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Delete confirmation modal -->
<form method="post" asp-page-handler="Delete" id="deleteForm">
    <input type="hidden" name="id" id="deleteId" />
</form>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center py-4">
                <i class="bi bi-exclamation-triangle text-danger fs-2"></i>
                <p class="mt-2 mb-1 fw-semibold">Delete venue?</p>
                <p class="text-muted small" id="deleteVenueName"></p>
            </div>
            <div class="modal-footer justify-content-center border-0">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" onclick="document.getElementById('deleteForm').submit()">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteVenueName').textContent = name;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}
