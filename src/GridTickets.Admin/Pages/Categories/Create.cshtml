@page
@model GridTickets.Admin.Pages.Categories.CategoryCreateModel
@{
    ViewData["Title"] = "Add Category";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-semibold">Add Category</h5>
    <a asp-page="/Categories/Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="card border-0 shadow-sm" style="max-width:560px;">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

            <div class="mb-3">
                <label class="form-label fw-medium">Name <span class="text-danger">*</span></label>
                <input asp-for="Input.Name" class="form-control" placeholder="e.g. Sports" />
                <span asp-validation-for="Input.Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label fw-medium">Slug <span class="text-danger">*</span></label>
                <input asp-for="Input.Slug" class="form-control" placeholder="e.g. sports" id="slugInput" />
                <div class="form-text">Lowercase, hyphens only. Auto-filled from name.</div>
                <span asp-validation-for="Input.Slug" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label class="form-label fw-medium">Description</label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"
                          placeholder="Optional description"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Save Category
                </button>
                <a asp-page="/Categories/Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('[name="Input.Name"]').addEventListener('input', function () {
            const slug = this.value.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
            document.getElementById('slugInput').value = slug;
        });
    </script>
}
