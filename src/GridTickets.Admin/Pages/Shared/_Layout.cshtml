<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GridTickets Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { width: 260px; min-height: 100vh; background: #1a1a2e; flex-shrink: 0; }
        .sidebar .nav-link { color: #adb5bd; border-radius: 6px; margin: 2px 8px; padding: 8px 12px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: #16213e; }
        .sidebar .nav-link i { width: 20px; }
        .sidebar-brand { color: #fff; font-size: 1.25rem; font-weight: 700; }
        .sidebar-brand span { color: #e94560; }
        .main-content { flex: 1; min-width: 0; }
        .topbar { background: #fff; border-bottom: 1px solid #dee2e6; }
    </style>
</head>
<body>
<div class="d-flex">
    <!-- Sidebar -->
    <nav class="sidebar d-flex flex-column py-3">
        <a class="sidebar-brand px-3 mb-4 text-decoration-none" asp-page="/Index">
            <i class="bi bi-ticket-perforated-fill me-2"></i>Grid<span>Tickets</span>
        </a>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")"
                   asp-page="/Index">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Users") == true ? "active" : "")"
                   asp-page="/Users/Index">
                    <i class="bi bi-people me-2"></i> Users
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Events") == true ? "active" : "")"
                   asp-page="/Events/Index">
                    <i class="bi bi-calendar-event me-2"></i> Events
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Venues") == true ? "active" : "")"
                   asp-page="/Venues/Index">
                    <i class="bi bi-geo-alt me-2"></i> Venues
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Categories") == true ? "active" : "")"
                   asp-page="/Categories/Index">
                    <i class="bi bi-tags me-2"></i> Categories
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Cities") == true ? "active" : "")"
                   asp-page="/Cities/Index">
                    <i class="bi bi-buildings me-2"></i> Cities
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Collections") == true ? "active" : "")"
                   asp-page="/Collections/Index">
                    <i class="bi bi-collection me-2"></i> Collections
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Orders") == true ? "active" : "")"
                   asp-page="/Orders/Index">
                    <i class="bi bi-receipt me-2"></i> Orders
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/hangfire" target="_blank">
                    <i class="bi bi-gear me-2"></i> Hangfire
                    <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                </a>
            </li>
        </ul>
        <div class="mt-auto px-3">
            <form method="post" asp-page="/Auth/Logout">
                <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                    <i class="bi bi-box-arrow-left me-1"></i> Logout
                </button>
            </form>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content d-flex flex-column">
        <div class="topbar px-4 py-2 d-flex align-items-center justify-content-between">
            <h6 class="mb-0 text-muted fw-semibold">@ViewData["Title"]</h6>
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-person-circle fs-5 text-secondary"></i>
                <span class="small text-secondary">@User.Identity?.Name</span>
            </div>
        </div>
        <main class="p-4">
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
