@page "{id:guid}"
@model GridTickets.Admin.Pages.Users.UserDetailModel
@{
    ViewData["Title"] = "User Detail";
}

@if (Model.User is null)
{
    <div class="alert alert-danger">User not found.</div>
    return;
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <div class="bg-secondary bg-opacity-10 rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center"
                     style="width:80px;height:80px">
                    <i class="bi bi-person-fill fs-1 text-secondary"></i>
                </div>
                <h5 class="mb-1">@Model.User.FullName</h5>
                <p class="text-muted small mb-2">@Model.User.Email</p>
                @foreach (var role in Model.User.Roles)
                {
                    <span class="badge bg-primary me-1">@role</span>
                }
            </div>
            <div class="card-footer bg-white border-0 text-center">
                <span class="badge fs-6 @(Model.User.Status == "Active" ? "bg-success" : Model.User.Status == "Suspended" ? "bg-danger" : "bg-secondary")">
                    @Model.User.Status
                </span>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="mb-0 fw-semibold">Account Details</h6>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">User ID</dt>
                    <dd class="col-sm-8 font-monospace small">@Model.User.Id</dd>

                    <dt class="col-sm-4 text-muted">Full Name</dt>
                    <dd class="col-sm-8">@Model.User.FullName</dd>

                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">@Model.User.Email</dd>

                    <dt class="col-sm-4 text-muted">Phone</dt>
                    <dd class="col-sm-8">@(Model.User.PhoneNumber ?? "—")</dd>

                    <dt class="col-sm-4 text-muted">Email Confirmed</dt>
                    <dd class="col-sm-8">
                        @if (Model.User.EmailConfirmed)
                        {
                            <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Yes</span>
                        }
                        else
                        {
                            <span class="text-warning"><i class="bi bi-exclamation-circle-fill me-1"></i>No</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted">Joined</dt>
                    <dd class="col-sm-8">@Model.User.CreatedAt.ToString("dd MMMM yyyy, HH:mm") UTC</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-page="/Users/Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Users
    </a>
</div>
